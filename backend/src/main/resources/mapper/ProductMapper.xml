<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shop.mapper.ProductMapper">
    <resultMap id="BaseResultMap" type="com.shop.entity.Product">
        <id column="id" property="id"/>
        <result column="category_id" property="categoryId"/>
        <result column="name" property="name"/>
        <result column="subtitle" property="subtitle"/>
        <result column="main_image" property="mainImage"/>
        <result column="detail" property="detail"/>
        <result column="price" property="price"/>
        <result column="stock" property="stock"/>
        <result column="sales_count" property="salesCount"/>
        <result column="review_count" property="reviewCount"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="CategorySubIds">
        SELECT id FROM category WHERE id = #{query.categoryId} OR parent_id = #{query.categoryId}
    </sql>

    <select id="selectByCondition" resultMap="BaseResultMap">
        SELECT * FROM product
        <where>
            <if test="categoryId != null">AND category_id = #{categoryId}</if>
            <if test="keyword != null and keyword != ''">AND (name LIKE CONCAT('%', #{keyword}, '%') OR subtitle LIKE CONCAT('%', #{keyword}, '%'))</if>
            <if test="status != null">AND status = #{status}</if>
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectByAdvancedCondition" parameterType="com.shop.dto.ProductQueryDTO" resultMap="BaseResultMap">
        SELECT DISTINCT p.* FROM product p
        <where>
            <if test="query.status != null">AND p.status = #{query.status}</if>
            <if test="query.keyword != null and query.keyword != ''">
                AND (p.name LIKE CONCAT('%', #{query.keyword}, '%') OR p.subtitle LIKE CONCAT('%', #{query.keyword}, '%'))
            </if>
            <if test="query.categoryId != null">
                AND p.category_id IN (<include refid="CategorySubIds"/>)
            </if>
            <if test="query.minPrice != null">AND p.price <![CDATA[>=]]> #{query.minPrice}</if>
            <if test="query.maxPrice != null">AND p.price <![CDATA[<=]]> #{query.maxPrice}</if>
            <if test="query.stockStatus != null and query.stockStatus == 'in_stock'">AND p.stock <![CDATA[>]]> 0</if>
            <if test="query.stockStatus != null and query.stockStatus == 'out_of_stock'">AND p.stock = 0</if>
            <if test="query.stockStatus != null and query.stockStatus == 'pre_sale'">AND p.stock <![CDATA[<]]> 0</if>
            <if test="query.startDate != null">AND p.created_at <![CDATA[>=]]> #{query.startDate}</if>
            <if test="query.endDate != null">AND p.created_at <![CDATA[<=]]> #{query.endDate}</if>
        </where>
        <choose>
            <when test="query.sortBy != null and query.sortBy == 'price' and query.sortOrder == 'asc'">ORDER BY p.price ASC</when>
            <when test="query.sortBy != null and query.sortBy == 'price' and query.sortOrder == 'desc'">ORDER BY p.price DESC</when>
            <when test="query.sortBy != null and query.sortBy == 'sales'">ORDER BY p.sales_count DESC</when>
            <when test="query.sortBy != null and query.sortBy == 'new_arrivals'">ORDER BY p.created_at DESC</when>
            <when test="query.sortBy != null and query.sortBy == 'reviews'">ORDER BY p.review_count DESC</when>
            <otherwise>ORDER BY p.id DESC</otherwise>
        </choose>
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM product WHERE id = #{id}
    </select>
    <update id="updateStock">
        UPDATE product SET stock = stock - #{quantity} WHERE id = #{id} AND stock >= #{quantity}
    </update>
    <update id="updateMainImage">
        UPDATE product SET main_image = #{mainImage} WHERE id = #{id}
    </update>
    <update id="updatePrice">
        UPDATE product SET price = #{price} WHERE id = #{id}
    </update>

    <sql id="AdminWhereClause">
        <where>
            <if test="query.name != null and query.name != ''">
                AND name LIKE CONCAT('%', #{query.name}, '%')
            </if>
            <if test="query.categoryId != null">
                AND category_id = #{query.categoryId}
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
            <if test="query.minPrice != null">
                AND price <![CDATA[>=]]> #{query.minPrice}
            </if>
            <if test="query.maxPrice != null">
                AND price <![CDATA[<=]]> #{query.maxPrice}
            </if>
        </where>
    </sql>

    <select id="selectByAdminCondition" parameterType="com.shop.dto.AdminProductQueryDTO" resultMap="BaseResultMap">
        SELECT * FROM product
        <include refid="AdminWhereClause"/>
        ORDER BY id DESC
        LIMIT #{query.pageSize} OFFSET ${(query.pageNum - 1) * query.pageSize}
    </select>

    <select id="countByAdminCondition" parameterType="com.shop.dto.AdminProductQueryDTO" resultType="long">
        SELECT COUNT(*) FROM product
        <include refid="AdminWhereClause"/>
    </select>

    <select id="selectByAdminConditionForExport" parameterType="com.shop.dto.AdminProductQueryDTO" resultMap="BaseResultMap">
        SELECT * FROM product
        <include refid="AdminWhereClause"/>
        ORDER BY id DESC
    </select>

    <select id="selectByIds" resultMap="BaseResultMap">
        SELECT * FROM product WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <update id="batchUpdateStatus">
        UPDATE product SET status = #{status} WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="batchUpdateCategory">
        UPDATE product SET category_id = #{categoryId} WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="batchUpdatePrice">
        UPDATE product SET price = #{price} WHERE id = #{id}
    </update>

    <insert id="insertProduct" parameterType="com.shop.entity.Product" useGeneratedKeys="true" keyProperty="product.id">
        INSERT INTO product (category_id, name, subtitle, main_image, detail, price, stock, status, created_at, updated_at)
        VALUES (
            #{product.categoryId},
            #{product.name},
            #{product.subtitle},
            #{product.mainImage},
            #{product.detail},
            #{product.price},
            #{product.stock},
            #{product.status},
            NOW(),
            NOW()
        )
    </insert>

    <select id="selectByCategoryOrderBySales" resultMap="BaseResultMap">
        SELECT * FROM product
        WHERE category_id = #{categoryId} AND status = 1 AND id != #{excludeId}
        ORDER BY sales_count DESC
        LIMIT #{limit}
    </select>

    <select id="selectRandomByCategory" resultMap="BaseResultMap">
        SELECT * FROM product
        WHERE category_id = #{categoryId} AND status = 1 AND id != #{excludeId}
        ORDER BY RAND()
        LIMIT #{limit}
    </select>

    <select id="selectTopBySales" resultMap="BaseResultMap">
        SELECT * FROM product
        WHERE status = 1
        ORDER BY sales_count DESC
        LIMIT #{limit}
    </select>
</mapper>
